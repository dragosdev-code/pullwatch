---
import { THEMES, THEME_STORAGE_KEY, DEFAULT_THEME } from '../lib/themes';

const themeJson = JSON.stringify(THEMES);
const themeLabels: Record<(typeof THEMES)[number], string> = {
  light: 'Light',
  dark: 'Dark',
};
---

<starlight-theme-select>
  <label class="sr-only" for="pw-docs-theme-select">Theme</label>
  <select
    id="pw-docs-theme-select"
    class="select select-bordered select-sm w-28 max-w-32"
    aria-label="Color theme"
    data-themes={themeJson}
  >
    {THEMES.map((name) => (
      <option value={name}>{themeLabels[name]}</option>
    ))}
  </select>
</starlight-theme-select>

<script is:inline define:vars={{ THEME_STORAGE_KEY, DEFAULT_THEME }}>
  function applyDocsTheme(name) {
    const current = document.documentElement.getAttribute('data-theme');
    if (current !== name) {
      document.documentElement.setAttribute('data-theme', name);
    }
    try {
      localStorage.setItem(THEME_STORAGE_KEY, name);
    } catch {
      /* private mode */
    }
    const select = document.getElementById('pw-docs-theme-select');
    if (select && select.value !== name) select.value = name;
  }

  function loadSavedTheme() {
    try {
      const saved = localStorage.getItem(THEME_STORAGE_KEY);
      if (saved === 'light' || saved === 'dark') return saved;
    } catch {
      /* private mode */
    }
    return DEFAULT_THEME;
  }

  const select = document.getElementById('pw-docs-theme-select');
  if (!select) return;
  const themes = JSON.parse(select.dataset.themes || '[]');

  applyDocsTheme(loadSavedTheme());

  select.addEventListener('change', (e) => {
    const value = e.target?.value;
    if (value && themes.includes(value)) applyDocsTheme(value);
  });
</script>

<style>
  starlight-theme-select {
    display: flex;
    align-items: center;
  }
</style>
