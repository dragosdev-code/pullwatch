{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    /* `React` namespace in types (e.g. React.FC) without per-file imports; @types/react is UMD. */
    "allowUmdGlobalAccess": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /*
     * WHY [Vite parity]: `paths` only affects TypeScript resolution (editor + `tsc`); it does not
     * rewrite emitted imports. Vite already resolves `@common/*` in vite.config — duplicate the same
     * mapping here so extension + src agree without "works in bundle, red in IDE" drift.
     */
    "baseUrl": ".",
    "paths": {
      "@common/*": ["extension/common/*"]
    }
  },
  "include": ["src", "extension"]
}
